// prisma/schema.prisma
// Codes on Notes — Full Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Difficulty {
  Easy
  Medium
  Hard
}

enum Role {
  USER
  ADMIN
  PREMIUM
}

enum Language {
  python
  javascript
  java
  cpp
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed — only for credential login
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Premium
  isPremium         Boolean   @default(false)
  premiumExpiresAt  DateTime?
  stripeCustomerId  String?   @unique

  // Relations
  accounts    Account[]
  sessions    Session[]
  solvedProblems UserProblem[]
  bookmarks   Bookmark[]
  streak      Streak?
  submissions Submission[]
  roadmapProgress RoadmapProgress[]
}

// ─── PROBLEM ──────────────────────────────────────────────────────────────────

model Topic {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  order    Int       @default(0)
  problems Problem[]
  roadmapTopics RoadmapTopic[]
}

model Problem {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  number      Int?       @unique
  difficulty  Difficulty
  topicId     String
  topic       Topic      @relation(fields: [topicId], references: [id])
  statement   String     @db.Text
  isPremium   Boolean    @default(false)
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Content
  solutions    Solution[]
  visualCode   String?    @db.Text  // sandboxed viz code
  pdfUrl       String?               // Cloudinary/S3 URL
  hints        String[]              // array of hint strings

  // Relations
  solvedBy   UserProblem[]
  bookmarks  Bookmark[]
  submissions Submission[]

  @@index([topicId])
  @@index([difficulty])
}

model Solution {
  id         String   @id @default(cuid())
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language   Language
  code       String   @db.Text
  explanation String? @db.Text
  timeComplexity  String?
  spaceComplexity String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([problemId, language])
}

// ─── USER PROGRESS ────────────────────────────────────────────────────────────

model UserProblem {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  solvedAt  DateTime @default(now())
  language  Language?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
}

// ─── STREAK ───────────────────────────────────────────────────────────────────

model Streak {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastSolvedAt  DateTime?
  activeDays    DateTime[] // list of dates user solved

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SUBMISSIONS (Code Playground) ───────────────────────────────────────────

model Submission {
  id        String   @id @default(cuid())
  userId    String
  problemId String?
  language  Language
  code      String   @db.Text
  output    String?  @db.Text
  status    String   // Accepted, Wrong Answer, TLE, etc.
  runtime   Int?     // ms
  memory    Int?     // KB
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem? @relation(fields: [problemId], references: [id])

  @@index([userId])
}

// ─── ROADMAP ──────────────────────────────────────────────────────────────────

model RoadmapLevel {
  id     String         @id @default(cuid())
  name   String         @unique  // Beginner, Intermediate, Advanced
  order  Int
  color  String         @default("#00ff87")
  topics RoadmapTopic[]
}

model RoadmapTopic {
  id       String       @id @default(cuid())
  levelId  String
  topicId  String
  order    Int
  level    RoadmapLevel @relation(fields: [levelId], references: [id])
  topic    Topic        @relation(fields: [topicId], references: [id])
  progress RoadmapProgress[]
}

model RoadmapProgress {
  id             String       @id @default(cuid())
  userId         String
  roadmapTopicId String
  completedAt    DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapTopic RoadmapTopic @relation(fields: [roadmapTopicId], references: [id])

  @@unique([userId, roadmapTopicId])
}

// ─── RESOURCES ────────────────────────────────────────────────────────────────

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String   // Cloudinary/S3
  fileSize    String?
  topic       String?
  isPublished Boolean  @default(true)
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
